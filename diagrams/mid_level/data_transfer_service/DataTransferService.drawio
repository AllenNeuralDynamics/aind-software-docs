          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="UL96ZQgQ9Tx9a3Nr9wBj-19" parent="SpeKbif7ejOxNLxw_tv2-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontSize=14;" value="&lt;div&gt;To initiate an upload, an Authorized User will need to:&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1. Register their acquisition and instrument to the Biodata Registry via the metadata service API.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;2. Move their data asset to VAST&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;3. Register the data asset to the Biodata Registry.&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;4. Send a compress and upload request to biodata‑transfer-service. The transfer service will need the Acquisition ID, desired S3 bucket, and a job_type per modality.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;The transfer service will compress the data, add processing metadata to the Biodata Registry, upload the data to S3, update Biodata Registry Data Asset with the S3 location, and then trigger Code Ocean pipelines. &lt;/div&gt;" vertex="1">
          <mxGeometry height="630" width="260" x="900" y="-720" as="geometry" />
