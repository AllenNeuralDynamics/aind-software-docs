        <mxCell id="NNWn0GaiYbIRpi_h3Rv3-20" parent="SpeKbif7ejOxNLxw_tv2-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontSize=14;" value="&lt;div&gt;&lt;b&gt;Biodata Registry&lt;/b&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;An ETL process will parse the data from Dataverse to aind-data-schema compliant metadata and store it in the Biodata registry.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;A user can fetch, update, and instruments via the allen-metadata-service.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;A user can upload acquisition or extracted acquisition metadata. The service will combine and transform the extracted acquisition files into a biodata-schema compliant file before adding it to the registry. &lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
